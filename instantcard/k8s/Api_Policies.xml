<policies>
    <inbound>
        <base />
        <validate-jwt header-name="Authorization" failed-validation-httpcode="401" failed-validation-error-message="No Autorizado. token invalido o expirado">
            <openid-config url="https://login.microsoftonline.com/{{tenantid}}/.well-known/openid-configuration" />
            <required-claims>
                <claim name="aud" match="any">
                    <value>{{appscopeges}}</value>
                </claim>
            </required-claims>
        </validate-jwt>
		<set-query-parameter name="scope" exists-action="append">
            <value>$(api.suffix)</value>
        </set-query-parameter>
		<!-- Cuota basada en el método HTTP -->
		<rate-limit-by-key calls="$(cuota.instant.card)" renewal-period="60" counter-key="@(context.Request.Method)" />
    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
        <set-header name="X-Powered-By" exists-action="delete" />
        <set-header name="X-Content-Type-Options" exists-action="override">
            <value>nosniff</value>
        </set-header>
        <set-header name="Strict-Transport-Security" exists-action="override">
            <value>max-age=31536000</value>
        </set-header>
        <set-header name="X-XSS-Protection" exists-action="override">
            <value>1; mode=block</value>
        </set-header>
        <set-header name="Content-Security-Policy" exists-action="override">
            <value>self</value>
        </set-header>
        <set-header name="X-Frame-Options" exists-action="override">
            <value>deny</value>
        </set-header>
        <set-header name="Expect-Ct" exists-action="override">
            <value>max-age=604800,enforce</value>
        </set-header>
        <set-header name="Cache-Control" exists-action="override">
            <value>none</value>
        </set-header>
        <set-header name="Content-Type" exists-action="override">
            <value>application/json</value>
        </set-header>
    </outbound>
    <on-error>
        <choose>
			<when condition="@(context.Response.StatusCode == 401)">
				<set-body>
					{        "errors": [        {            "code": "401",            "title": "Unauthorized",            "detail": "No Autorizado. token invalido o expirado"        }    ]}
				</set-body>
			</when>
			<when condition="@(context.Response.StatusCode == 429)">
				<set-body>
					{        "errors": [        {            "code": "429" ,            "title": "Quote Limited",            "detail": "Limite de cuota excedido"        }    ]}
				</set-body>
			</when>
			<otherwise />
		</choose>
        <base />
    </on-error>
</policies>
